{
  "family": "pulse-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::217757579310:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::217757579310:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "pulse-backend",
      "image": "217757579310.dkr.ecr.ap-south-1.amazonaws.com/axiora/pulse-fastapi:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ENVIRONMENT", "value": "production" },
        { "name": "ALGORITHM",   "value": "HS256" }
      ],
      "secrets": [
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/SECRET_KEY"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/DATABASE_URL"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/OPENAI_API_KEY"
        },
        {
          "name": "GOOGLE_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/GOOGLE_API_KEY"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/RESEND_API_KEY"
        },
        {
          "name": "EMAIL_FROM",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/EMAIL_FROM"
        },
        {
          "name": "FRONTEND_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/FRONTEND_URL"
        },
        {
          "name": "EMAIL_USER",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/EMAIL_USER"
        },
        {
          "name": "EMAIL_PASS",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/EMAIL_PASS"
        },
        {
          "name": "RAZORPAY_KEY_ID",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/RAZORPAY_KEY_ID"
        },
        {
          "name": "RAZORPAY_KEY_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:217757579310:parameter/axiorapulse/production/RAZORPAY_KEY_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/pulse-backend",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 40
      }
    }
  ]
}
